# ==========================================
# Archivo de ejemplo: .env.example
# ==========================================
# Copia este archivo a .env y rellena con tus valores
# NO subas el archivo .env a Git (ya está en .gitignore)

# ==========================================
# Base de Datos - PostgreSQL
# ==========================================
DB_URL=jdbc:postgresql://localhost:5432/mi_base_db
DB_USERNAME=root
DB_PASSWORD=root
DB_DRIVER=org.postgresql.Driver

# ==========================================
# Base de Datos Test- PostgreSQL
# ==========================================
DB_TEST_URL=jdbc:postgresql://localhost:5432/user_test_db
DB_TEST_USERNAME=root
DB_TEST_PASSWORD=root


# ==========================================
# Servidor
# ==========================================
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/

# ==========================================
# JPA / Hibernate
# ==========================================
JPA_SHOW_SQL=true
JPA_GENERATE_DDL=true
JPA_HIBERNATE_DDL_AUTO=update

# ==========================================
# Logging
# ==========================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_EXAMPLE=DEBUG

# ==========================================
# Pokemon API
# ==========================================
POKEMON_API_TIMEOUT_SECONDS=10
POKEMON_API_MAX_CONNECTIONS=50

# ==========================================
# Aplicacion
# ==========================================
APP_NAME=Base API
APP_DESCRIPTION=API para gestión de usuarios con Pokémons
APP_VERSION=1.0.0

